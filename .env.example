# Argus environment configuration — copy to .env and fill in your keys.
# .env is gitignored; .env.example is committed.

# ── Required ───────────────────────────────────────────────────────────────

# Anthropic API key — Sonnet 4.6 (triage + L1) + Opus 4.6 (escalation).
# Get one at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=


# ── Optional: alternate triage model ───────────────────────────────────────

# Google AI Studio key — only needed if you pass `--triage-model
# gemini-flash-lite`. The v15.9 default is Sonnet 4.6 triage (deterministic,
# ~$0.02/file). Flash-Lite is cheaper (~$0.001/file) but slightly higher
# variance. Get a key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=


# ── Optional: DAST sandbox (Finding Validation + Remediation) ──────────────

# Without DAST configured, Argus runs the L1 cascade and returns verdicts
# without sandbox-grounded CONFIRMED evidence — and Remediation can't fire.
# Full setup: docs/dast-setup.md.

# Substrate selector. `gvisor` = self-hosted (local Docker + the runsc
# runtime; no Fly account, no egress) — the recommended default for
# self-hosted deployments. `fly` (default if unset) = managed Firecracker
# microVMs on your Fly account. Pick ONE block below.
# ARGUS_DAST_RUNTIME=gvisor

# ── Option A: self-hosted gVisor (set ARGUS_DAST_RUNTIME=gvisor above) ──
# Build images locally with: cd dast/sandbox/firecracker && bash build_local.sh
# These default tags match build_local.sh's output; RICH_PYTHON + ML_TOOLS
# fall back to LEAN when unset. No FLY_API_TOKEN needed for this path.
# ARGUS_DAST_GVISOR_IMAGE_LEAN=argus-dast-sandbox:lean
# ARGUS_DAST_GVISOR_IMAGE_RICH_PYTHON=argus-dast-sandbox:rich_python
# ARGUS_DAST_GVISOR_IMAGE_ML_TOOLS=argus-dast-sandbox:ml_tools
# ARGUS_DAST_GVISOR_RUNTIME=runsc      # OCI runtime name (default runsc)
# ARGUS_DAST_GVISOR_NETWORK=none       # docker net mode; none = no egress

# ── Option B: managed Fly.io (default; ARGUS_DAST_RUNTIME unset or =fly) ──
# Fly.io API token (deploy-scoped, 30-day expiry). Generated by
# `flyctl tokens create deploy --app "$ARGUS_DAST_FLY_APP" --expiry 720h`.
FLY_API_TOKEN=

# Your Fly app name. Fly app names are GLOBALLY unique across all Fly
# accounts. The default `argus-dast-sandbox` is taken by the upstream
# project — self-hosters MUST pick their own (e.g., argus-dast-<handle>).
# This must match the app you created via preflight.sh / preflight.ps1.
ARGUS_DAST_FLY_APP=argus-dast-sandbox

# DAST sandbox image refs. Replace `argus-dast-sandbox` with your
# ARGUS_DAST_FLY_APP value. Bump the `vN` tag suffix when you rebuild
# images (via `IMAGE_VERSION=vN bash build_and_push_multi.sh`).
#
# Only ECHO_DAST_IMAGE_LEAN is strictly required — RICH_PYTHON + ML_TOOLS
# fall back to LEAN when unset.
ECHO_DAST_IMAGE_LEAN=registry.fly.io/argus-dast-sandbox:lean-v1
ECHO_DAST_IMAGE_RICH_PYTHON=registry.fly.io/argus-dast-sandbox:rich_python-v1
ECHO_DAST_IMAGE_ML_TOOLS=registry.fly.io/argus-dast-sandbox:ml_tools-v1

# Optional: Fly region for the sandbox app. Default: iad.
# ARGUS_DAST_FLY_REGION=iad


# ── Optional: adjudicator override ─────────────────────────────────────────

# Override the verdict-adjudication model. Defaults to claude-opus-4-6.
# VERDICT_MODEL=claude-opus-4-6


# ── Optional: BENCH-011 GPT independent judge ──────────────────────────────

# OpenAI API key — used ONLY by methodology/judge.py (BENCH-011) to ask
# GPT-5.5 to adjudicate disagreements between Argus / vanilla Opus / oracle.
# Not needed for normal scans. Get one at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Override the judge model. Defaults to gpt-5.5.
# JUDGE_MODEL=gpt-5.5
