# Argus environment configuration — copy to .env and fill in your keys.
# .env is gitignored; .env.example is committed.

# ── Required for cascade analysis ──────────────────────────────────────────

# Anthropic API key — used by the Sonnet 4.6 + Opus 4.7 analysis runners.
# Get one at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Google AI Studio API key — used by Gemini Flash-Lite triage runner.
# Get one at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=


# ── Optional: DAST verification (Phase 3) ──────────────────────────────────

# Fly.io API token — used to dispatch DAST sandbox containers. Only needed
# if you want DAST verification on confirmed-malicious files. Without this
# token, the engine still runs the L1 cascade and skips DAST.
# Get one at: https://fly.io/user/personal_access_tokens
FLY_API_TOKEN=

# DAST sandbox image tags. Defaults assume you've stood up your own
# argus-dast-sandbox Fly app per dast/sandbox/firecracker/RUNBOOK.md.
ECHO_DAST_IMAGE_MINIMAL=registry.fly.io/argus-dast-sandbox:minimal-v1
ECHO_DAST_IMAGE_NETWORKED=registry.fly.io/argus-dast-sandbox:networked-v1
ECHO_DAST_IMAGE_ML_TOOLS=registry.fly.io/argus-dast-sandbox:ml_tools-v1


# ── Optional: adjudicator overrides ────────────────────────────────────────

# Override the verdict-adjudication model. Defaults to claude-opus-4-6.
# VERDICT_MODEL=claude-opus-4-6


# ── Optional: BENCH-011 GPT-5 independent judge ────────────────────────────

# OpenAI API key — used ONLY by methodology/judge.py (BENCH-011) to ask
# GPT-5.5 to adjudicate disagreements between Argus / vanilla Opus / oracle.
# Not needed for normal scans. Get one at: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Override the judge model. Defaults to gpt-5.5.
# JUDGE_MODEL=gpt-5.5
